generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               Int              @id @default(autoincrement())
  fullName         String
  email            String           @unique
  photo            String?
  password         String
  position         String
  role             Role
  hire_date        DateTime
  address          String?
  status           UserStatus       @default(ACTIVE)
  created_at       DateTime         @default(now())
  updated_at       DateTime         @updatedAt
  resetToken       String?
  resetTokenExpiry DateTime?
  userAttendence   Attendance[]
  groups           Group[]
  userHomework     Homework[]
  HomeworkResult   HomeworkResult[]
  userLesson       Lesson[]
  lessonVideo      LessonVideo[]
}

model Teacher {
  id                Int              @id @default(autoincrement())
  fullName          String
  email             String           @unique
  photo             String?
  password          String
  position          String
  experience        Int
  status            UserStatus       @default(ACTIVE)
  created_at        DateTime         @default(now())
  updated_at        DateTime         @updatedAt
  teacherAttendence Attendance[]
  groups            Group[]
  homework          Homework[]
  HomeworkResult    HomeworkResult[]
  teacherLessons    Lesson[]
  lessonVideo       LessonVideo[]
  rating            Rating[]
}

model Student {
  id                Int                @id @default(autoincrement())
  fullName          String
  email             String             @unique
  photo             String?
  password          String
  birth_date        DateTime
  status            UserStatus         @default(ACTIVE)
  created_at        DateTime           @default(now())
  updated_at        DateTime           @updatedAt
  StudentAttendence Attendance[]
  HomeworkResponse  HomeworkResponse[]
  HomeworkResult    HomeworkResult[]
  StudentGroups     StudentGroup[]
}

model Course {
  id             Int          @id @default(autoincrement())
  name           String       @unique
  durationMonth  Int
  durationLesson Int
  status         Status
  level          CourseLevel?
  price          Decimal
  description    String?
  created_at     DateTime     @default(now())
  updated_at     DateTime     @updatedAt
  groups         Group[]
}

model Room {
  id         Int      @id @default(autoincrement())
  name       String   @unique
  capacity   Int
  status     Status   @default(ACTIVE)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  groups     Group[]
}

model Group {
  id           Int            @id @default(autoincrement())
  teacherId    Int
  userId       Int
  roomId       Int
  courseId     Int
  name         String         @unique
  capacity     Int
  startDate    DateTime
  startTime    String
  weekDays     WeekDays[]
  status       Status         @default(ACTIVE)
  created_at   DateTime       @default(now())
  updated_at   DateTime       @updatedAt
  course       Course         @relation(fields: [courseId], references: [id])
  room         Room           @relation(fields: [roomId], references: [id])
  teacher      Teacher        @relation(fields: [teacherId], references: [id])
  user         User           @relation(fields: [userId], references: [id])
  lesson       Lesson[]
  studentGroup StudentGroup[]

  @@unique([courseId, name])
}

model StudentGroup {
  id         Int      @id @default(autoincrement())
  groupId    Int
  studentId  Int
  status     Status   @default(ACTIVE)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  group      Group    @relation(fields: [groupId], references: [id])
  student    Student  @relation(fields: [studentId], references: [id])

  @@unique([groupId, studentId])
}

model Lesson {
  id             Int           @id @default(autoincrement())
  groupId        Int
  title          String
  userId         Int?
  teacherId      Int?
  created_at     DateTime      @default(now())
  updated_at     DateTime      @updatedAt
  lesson         Attendance[]
  lessonHomework Homework[]
  group          Group         @relation(fields: [groupId], references: [id])
  teacher        Teacher?      @relation(fields: [teacherId], references: [id])
  user           User?         @relation(fields: [userId], references: [id])
  lessonVideo    LessonVideo[]
  rating         Rating[]
}

model Attendance {
  id         Int      @id @default(autoincrement())
  lessonId   Int
  userId     Int?
  teacherId  Int?
  studentId  Int
  isPresent  Boolean
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  lesson     Lesson   @relation(fields: [lessonId], references: [id])
  student    Student  @relation(fields: [studentId], references: [id])
  teacher    Teacher? @relation(fields: [teacherId], references: [id])
  user       User?    @relation(fields: [userId], references: [id])
}

model Homework {
  id               Int                @id @default(autoincrement())
  lessonId         Int
  userId           Int?
  teacherId        Int?
  title            String
  file             String?
  created_at       DateTime           @default(now())
  updated_at       DateTime           @updatedAt
  durationTime     Int                @default(16)
  lesson           Lesson             @relation(fields: [lessonId], references: [id])
  teacher          Teacher?           @relation(fields: [teacherId], references: [id])
  user             User?              @relation(fields: [userId], references: [id])
  homeworkResponse HomeworkResponse[]
  homeworkResult   HomeworkResult[]
}

model LessonVideo {
  id         Int      @id @default(autoincrement())
  lessonId   Int
  userId     Int?
  teacherId  Int?
  title      String
  file       String
  created_at DateTime @default(now())
  lesson     Lesson   @relation(fields: [lessonId], references: [id])
  teacher    Teacher? @relation(fields: [teacherId], references: [id])
  user       User?    @relation(fields: [userId], references: [id])
}

model HomeworkResponse {
  id         Int                   @id @default(autoincrement())
  homeworkId Int
  studentId  Int
  title      String
  file       String?
  status     HomeworkStatusStudent
  created_at DateTime              @default(now())
  updated_at DateTime              @updatedAt
  homework   Homework              @relation(fields: [homeworkId], references: [id])
  student    Student               @relation(fields: [studentId], references: [id])
}

model HomeworkResult {
  id         Int            @id @default(autoincrement())
  homeworkId Int
  studentId  Int
  userId     Int?
  teacherId  Int?
  title      String
  file       String?
  score      Int
  status     HomeworkStatus
  created_at DateTime       @default(now())
  updated_at DateTime       @updatedAt
  homework   Homework       @relation(fields: [homeworkId], references: [id])
  student    Student        @relation(fields: [studentId], references: [id])
  teacher    Teacher?       @relation(fields: [teacherId], references: [id])
  user       User?          @relation(fields: [userId], references: [id])
}

model Rating {
  id         Int      @id @default(autoincrement())
  teacherId  Int
  lessonId   Int
  score      Int
  created_at DateTime @default(now())
  lesson     Lesson   @relation(fields: [lessonId], references: [id])
  teacher    Teacher  @relation(fields: [teacherId], references: [id])
}

enum Status {
  ACTIVE
  INACTIVE
}

enum UserStatus {
  ACTIVE
  INACTIVE
  FREEZE
}

enum CourseLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum WeekDays {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum HomeworkStatus {
  APPROVED
  REJECTED
  PENDING
}

enum HomeworkStatusStudent {
  COMPLETED
  MISSED
  DELAY
}

enum Role {
  SUPERADMIN
  ADMIN
  STUDENT
  TEACHER
  MANAGEMENT
  ADMINSTRATOR
}
